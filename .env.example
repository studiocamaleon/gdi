# Copia este archivo a .env y completa los valores reales.

# Backend (NestJS)
PORT=3001
FRONTEND_URL=http://localhost:3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5436/gdi_saas?schema=public&connection_limit=20&pool_timeout=20"
JWT_SECRET=change-in-production

# Etapa B.5 — Feature flags del modelo universal
# Cuando ENABLE_WIDE_FORMAT_V2=true, el endpoint /cotizar-v2 rutea al motor
# gran_formato@2 nativo para productos wide-format. Default: false (usa adapter v1).
ENABLE_WIDE_FORMAT_V2=false

# NEXT_PUBLIC_ENABLE_WIDE_FORMAT_V2 (frontend Next.js): cuando true,
# agrega el tab "Simular costo (v2)" en productos wide-format.
# Default: false. Para probar el piloto, activar ambos flags y reiniciar servers.
NEXT_PUBLIC_ENABLE_WIDE_FORMAT_V2=false
