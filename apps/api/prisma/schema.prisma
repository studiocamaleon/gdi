// Modelo universal (A.4): regla declarativa que resuelve puntos de decisión
// (material, centro de costo, variante, activación, parámetro) sin intervención
// manual. Evaluada por el motor v2 contra el Job Context + outputs previos.
// Sin consumidores al 2026-04-17; se activará en Etapas B/C.
model ReglaDeSeleccion {
  id              String                @id @default(uuid()) @db.Uuid
  tenantId        String                @db.Uuid
  nombre          String
  descripcion     String?
  dominio         DominioReglaSeleccion
  targetRef       String?               // id del paso/material/centro sobre el que decide (FK lógica, no enforceable)
  inputs          Json                  // string[] — variables del Job Context u outputs previos que lee
  casos           Json                  // Array<{ condicion: JsonLogicExpr, decision: JsonValue }>
  defaultDecision Json?                 // decisión si ningún caso matchea (opcional; sin default → rechaza cotización)
  activa          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, dominio, activa])
  @@index([tenantId, targetRef])
}

