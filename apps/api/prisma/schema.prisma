// Modelo universal (A.3): modo de activación de un paso en la ruta efectiva.
// OBLIGATORIO   → siempre se ejecuta.
// OPCIONAL      → se ejecuta si el cliente/operador lo eligió.
// CONDICIONAL   → se ejecuta si la expresión JsonLogic en condicionV2 evalúa true.
enum ActivacionPasoV2 {
  OBLIGATORIO
  OPCIONAL
  CONDICIONAL
}

// Modelo universal (A.4): dominio sobre el que decide una ReglaDeSeleccion.
// MATERIAL       → elige qué MateriaPrimaVariante consume un paso.
// CENTRO_COSTO   → elige qué centro/máquina ejecuta un paso.
// VARIANTE_PASO  → elige una variante/nivel del paso.
// ACTIVACION     → decide si el paso se ejecuta (condicional).
// PARAMETRO      → decide el valor de un parámetro del paso (ej. caras_laminado = 1 o 2).
enum DominioReglaSeleccion {
  MATERIAL
  CENTRO_COSTO
  VARIANTE_PASO
  ACTIVACION
  PARAMETRO
}

