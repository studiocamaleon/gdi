  updatedAt                              DateTime                                @updatedAt
  memberships                            Membership[]
  authSessions                           AuthSession[]
  invitations                            Invitation[]
  clientes                               Cliente[]
  proveedores                            Proveedor[]
  empleados                              Empleado[]
  plantas                                Planta[]
  areasCosto                             AreaCosto[]
  centrosCosto                           CentroCosto[]
  centroCostoRecursos                    CentroCostoRecurso[]
  centroCostoRecursosMaquinaria          CentroCostoRecursoMaquinaPeriodo[]
  centroCostoComponentesCostoPeriodo     CentroCostoComponenteCostoPeriodo[]
  centroCostoCapacidadesPeriodo          CentroCostoCapacidadPeriodo[]
  centroCostoTarifasPeriodo              CentroCostoTarifaPeriodo[]
