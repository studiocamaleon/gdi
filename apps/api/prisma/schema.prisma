  requiresProductoAdicional   ProductoAdicionalCatalogo? @relation("ProductoAdicionalCondicionOperacion", fields: [requiresProductoAdicionalId], references: [id], onDelete: SetNull)
  productoChecklistReglasPaso ProductoChecklistRegla[]   @relation("ProductoChecklistReglaOperacion")

  @@unique([tenantId, procesoDefinicionId, orden])
  @@unique([tenantId, procesoDefinicionId, codigo])
  @@index([tenantId, procesoDefinicionId, activo])
  @@index([tenantId, centroCostoId])
