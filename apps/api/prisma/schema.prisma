  productosServicioAdicionales           ProductoServicioAdicional[]
  productosVarianteAdicionales           ProductoVarianteAdicionalRestriction[]
  productosAdicionalMateriales           ProductoAdicionalMaterial[]
  productoVarianteOpcionProductivaSets   ProductoVarianteOpcionProductivaSet[]
  productoVarianteOpcionProductivaValues ProductoVarianteOpcionProductivaValue[]
