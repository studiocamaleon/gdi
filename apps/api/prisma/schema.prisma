  perfilOperativoId           String?                    @db.Uuid
  setupMin                    Decimal?                   @db.Decimal(12, 2)
  runMin                      Decimal?                   @db.Decimal(12, 2)
  cleanupMin                  Decimal?                   @db.Decimal(12, 2)
  tiempoFijoMin               Decimal?                   @db.Decimal(12, 2)
  multiplicadorDobleFaz       Decimal?                   @db.Decimal(5, 2)
  modoProductividad           ModoProductividadProceso   @default(FIJA)
  productividadBase           Decimal?                   @db.Decimal(12, 4)
