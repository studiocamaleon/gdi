  reglaMermaJson              Json?
  detalleJson                 Json?
  rol                         RolProcesoOperacion?
  esOpcional                  Boolean                    @default(false)
  requiresProductoAdicionalId String?                    @db.Uuid
  // ── Extensiones modelo universal (A.3) ─────────────────────────────
  // Todas nullable para mantener compatibilidad con motores v1.
  // Los motores v2 de Etapa B/C las consumirán cuando las rutas las declaren.
  familiaV2                   String?                    // FK lógica a pasos/familias.ts (código)
  leeDelTrabajoV2             Json?                      // string[] de variables del Job Context
  leeDePasosV2                Json?                      // string[] de outputs de pasos previos
  produceV2                   Json?                      // string[] de outputs canónicos emitidos
  unidadProductivaV2          String?                    // 'cantidad', 'hojas', 'letras', 'modulosLED', etc.
  activacionV2                ActivacionPasoV2?          // OBLIGATORIO | OPCIONAL | CONDICIONAL
  condicionV2                 Json?                      // JsonLogic expression si activacionV2 = CONDICIONAL
  // ───────────────────────────────────────────────────────────────────
  activo                      Boolean                    @default(true)
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt
  tenant                      Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  procesoDefinicion           ProcesoDefinicion          @relation(fields: [procesoDefinicionId], references: [id], onDelete: Cascade)
