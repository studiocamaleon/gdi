model User {
  id             String        @id @default(uuid()) @db.Uuid
  email          String        @unique
  passwordHash   String?
  nombreCompleto String?
  activo         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  memberships    Membership[]
  authSessions   AuthSession[]
  invitations    Invitation[]
  empleados      Empleado[]
}

model Membership {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @db.Uuid
  tenantId        String        @db.Uuid
  rol             RolSistema
  activa          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authSessions    AuthSession[]
  invitationsSent Invitation[]  @relation("InvitationSender")

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model AuthSession {
  id                  String     @id @default(uuid()) @db.Uuid
  userId              String     @db.Uuid
  currentTenantId     String     @db.Uuid
  currentMembershipId String     @db.Uuid
  expiresAt           DateTime
  revokedAt           DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentTenant       Tenant     @relation(fields: [currentTenantId], references: [id], onDelete: Cascade)
  currentMembership   Membership @relation(fields: [currentMembershipId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([currentTenantId])
}

model Invitation {
  id                    String     @id @default(uuid()) @db.Uuid
  tenantId              String     @db.Uuid
  userId                String?    @db.Uuid
  empleadoId            String?    @db.Uuid
  invitedByMembershipId String     @db.Uuid
  email                 String
  rol                   RolSistema
  tokenHash             String     @unique
  expiresAt             DateTime
  acceptedAt            DateTime?
  revokedAt             DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  tenant                Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  empleado              Empleado?  @relation(fields: [empleadoId], references: [id], onDelete: SetNull)
  invitedByMembership   Membership @relation("InvitationSender", fields: [invitedByMembershipId], references: [id], onDelete: Cascade)

  @@index([tenantId, email])
  @@index([empleadoId])
}

model Cliente {
  id             String             @id @default(uuid()) @db.Uuid
  tenantId       String             @db.Uuid
  nombre         String
  razonSocial    String?
  emailPrincipal String
  telefonoCodigo String
  telefonoNumero String
  paisCodigo     String             @db.VarChar(2)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactos      ClienteContacto[]
  direcciones    ClienteDireccion[]

  @@unique([tenantId, nombre])
  @@index([tenantId, nombre])
}

model Proveedor {
  id                              String                 @id @default(uuid()) @db.Uuid
  tenantId                        String                 @db.Uuid
  nombre                          String
  razonSocial                     String?
  emailPrincipal                  String
  telefonoCodigo                  String
  telefonoNumero                  String
  paisCodigo                      String                 @db.VarChar(2)
  createdAt                       DateTime               @default(now())
  updatedAt                       DateTime               @updatedAt
  tenant                          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactos                       ProveedorContacto[]
  direcciones                     ProveedorDireccion[]
  materiaPrimaVariantesReferencia MateriaPrimaVariante[] @relation("MateriaPrimaVarianteProveedorReferencia")

  @@unique([tenantId, nombre])
  @@index([tenantId, nombre])
}

model Empleado {
  id                    String               @id @default(uuid()) @db.Uuid
  tenantId              String               @db.Uuid
  userId                String?              @db.Uuid
  nombreCompleto        String
  emailPrincipal        String
  telefonoCodigo        String
  telefonoNumero        String
  sector                String
  ocupacion             String?
  sexo                  SexoEmpleado?
  fechaIngreso          DateTime             @db.Date
  fechaNacimiento       DateTime?            @db.Date
  comisionesHabilitadas Boolean              @default(false)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  tenant                Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  direcciones           EmpleadoDireccion[]
  comisiones            EmpleadoComision[]
  centrosACargo         CentroCosto[]        @relation("CentroCostoResponsable")
  invitations           Invitation[]
  recursosCentroCosto   CentroCostoRecurso[] @relation("CentroCostoRecursoEmpleado")

  @@index([tenantId, nombreCompleto])
  @@index([tenantId, sector])
}

model ClienteContacto {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  clienteId      String   @db.Uuid
  nombre         String
  cargo          String?
  email          String?
  telefonoCodigo String?
  telefonoNumero String?
  principal      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente        Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([tenantId, clienteId])
}

