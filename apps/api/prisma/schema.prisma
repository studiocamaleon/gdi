  maquinaPerfilesOperativos              MaquinaPerfilOperativo[]
  maquinaConsumibles                     MaquinaConsumible[]
  maquinaComponentesDesgaste             MaquinaComponenteDesgaste[]
  procesosDefinicion                     ProcesoDefinicion[]
  procesoOperacionPlantillas             ProcesoOperacionPlantilla[]
